# DGA Capital Research Analyst — Claude Edition
# Copy this file to `.env` and fill in your own values.
# Never commit `.env` to git.

# ---- xAI / Grok (REQUIRED) ----
# Get one at https://console.x.ai/
XAI_API_KEY=xai-REPLACE_WITH_YOUR_KEY
GROK_MODEL=grok-4.3

# ---- Gamma.app (REQUIRED only when Gamma deck generation is on) ----
# Get one at https://gamma.app/account
GAMMA_API_KEY=sk-gamma-REPLACE_WITH_YOUR_KEY
# Optional: target folder ID in your Gamma workspace. Leave blank for default.
GAMMA_FOLDER_ID=

# ---- SEC EDGAR (REQUIRED) ----
# SEC rate-limits/blocks anonymous scrapers; the UA must identify you.
# Format: "Your Name your.email@example.com"
SEC_USER_AGENT=Your Name your.email@example.com

# ---- SEC financials download location (OPTIONAL) ----
# Where pull_sec_financials.py writes the per-ticker 10-K + 10-Q Excel
# workbooks, and where excel_financials.py reads them from.
# Relative paths are resolved against the project root (this file's folder).
# Default is "stock-financials" — sibling of the stocks/ output folder.
STOCK_FINANCIALS_DIR=stock-financials

# ---- GuruFocus — live analyst ratings for Section 7.5 (RECOMMENDED) ----
# Fetches the most recent upgrades/downgrades for Goldman Sachs, Morgan Stanley,
# Merrill Lynch, Fidelity, and Morningstar and injects them into every report.
# Without this token, Grok falls back to its own training data (may be stale).
# Get your token at: https://www.gurufocus.com/api/authentication
GURUFOCUS_TOKEN=your_token_here

# ---- Google Sheets auto-push (OPTIONAL) ----
# After every portfolio run the results are written to three sheets in a Google
# Spreadsheet: "Portfolio" (weights), "Summary" (ratings/prices), "Run Log"
# (append-only audit trail).
#
# Setup (one-time):
#   1. Go to https://console.cloud.google.com/ → create a project.
#   2. Enable the Google Sheets API and Google Drive API.
#   3. Create a Service Account → download the JSON key file.
#   4. Open your target spreadsheet → Share it with the service account email
#      (e.g. dga-portfolio@your-project.iam.gserviceaccount.com) as an Editor.
#   5. Copy the Spreadsheet ID from the URL:
#      https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account-key.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# ---- Dropbox report cache (RECOMMENDED — works on personal accounts) ----
# Per-ticker .md and portfolio files are uploaded here so cached reports
# survive Railway redeploys. Files land in the "DGA Research Reports" folder
# in your personal Dropbox (no quota issues, no Google Workspace required).
#
# One-time setup:
#   1. Go to https://www.dropbox.com/developers/apps/create
#   2. Choose "Scoped access" → "Full Dropbox" → name it "DGA Research"
#   3. Under Permissions tab: check files.content.write, files.content.read,
#      files.metadata.read → Submit
#   4. Under Settings tab: copy App key and App secret
#   5. Run the one-time auth helper to get a refresh token:
#        python3 scripts/dropbox_auth.py <APP_KEY> <APP_SECRET>
#   6. Paste the three values into Railway (or your .env) below.
#
# Optional override:
#   DROPBOX_FOLDER_PATH — defaults to "/DGA Research Reports"
DROPBOX_APP_KEY=your_app_key_here
DROPBOX_APP_SECRET=your_app_secret_here
DROPBOX_REFRESH_TOKEN=your_refresh_token_here
#DROPBOX_FOLDER_PATH=/DGA Research Reports

# ---- Google Drive folder for cached reports (OPTIONAL) ----
# The script persists per-ticker report .md files so they survive Railway
# redeploys (the local /stocks folder is wiped on every deploy).
#
# IMPORTANT — Google policy gotcha:
#   A service account has ZERO personal-Drive storage quota. Sharing a regular
#   Drive folder with the service account does NOT make its uploads count
#   against your quota — that only works for Google Workspace Shared Drives
#   or with OAuth user-delegated credentials. With a personal Gmail account +
#   service account, direct folder uploads return 403 storageQuotaExceeded.
#
# How the script handles that:
#   1. It tries a real upload into the Drive folder named below (this works
#      only if the folder is a Workspace Shared Drive, or you've wired up
#      OAuth user creds).
#   2. On quota failure, it falls back to writing each report into a
#      ticker-named tab in the GOOGLE_SHEETS_SPREADSHEET_ID sheet. Service
#      accounts CAN mutate cells of a sheet you've shared with them, so this
#      works on every Google account type. The reports read back identically
#      on the next portfolio run — the Sheets tabs ARE your cache.
#
# Overrides (optional — only useful if you're on a Workspace Shared Drive):
#   - GOOGLE_DRIVE_FOLDER_NAME: defaults to "DGA Research Reports".
#   - GOOGLE_DRIVE_FOLDER_ID: skip name-lookup, use this folder ID directly.
#     Find the ID in the folder URL: drive.google.com/drive/folders/<FOLDER_ID>
#GOOGLE_DRIVE_FOLDER_NAME=DGA Research Reports
#GOOGLE_DRIVE_FOLDER_ID=

# ---- Portfolio analysis email notifications (OPTIONAL) ----
# When a PORTFOLIO analysis finishes (multi-ticker run), the script emails the
# results + attaches the docx + xlsx. Single-ticker runs do NOT email.
# Override the recipient (defaults to alecmazo1@gmail.com):
PORTFOLIO_EMAIL_TO=alecmazo1@gmail.com
# Sender Gmail credentials. Use a Gmail App Password (NOT your regular
# password). Create one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification on the Google account).
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
