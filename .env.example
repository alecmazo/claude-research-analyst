# DGA Capital Research Analyst — Claude Edition
# Copy this file to `.env` and fill in your own values.
# Never commit `.env` to git.

# ---- xAI / Grok (REQUIRED) ----
# Get one at https://console.x.ai/
XAI_API_KEY=xai-REPLACE_WITH_YOUR_KEY
GROK_MODEL=grok-4.20-reasoning

# ---- Gamma.app (REQUIRED only when Gamma deck generation is on) ----
# Get one at https://gamma.app/account
GAMMA_API_KEY=sk-gamma-REPLACE_WITH_YOUR_KEY
# Optional: target folder ID in your Gamma workspace. Leave blank for default.
GAMMA_FOLDER_ID=

# ---- SEC EDGAR (REQUIRED) ----
# SEC rate-limits/blocks anonymous scrapers; the UA must identify you.
# Format: "Your Name your.email@example.com"
SEC_USER_AGENT=Your Name your.email@example.com

# ---- SEC financials download location (OPTIONAL) ----
# Where pull_sec_financials.py writes the per-ticker 10-K + 10-Q Excel
# workbooks, and where excel_financials.py reads them from.
# Relative paths are resolved against the project root (this file's folder).
# Default is "stock-financials" — sibling of the stocks/ output folder.
STOCK_FINANCIALS_DIR=stock-financials

# ---- Portfolio analysis email notifications (OPTIONAL) ----
# When a PORTFOLIO analysis finishes (multi-ticker run), the script emails the
# results + attaches the docx + xlsx. Single-ticker runs do NOT email.
# Override the recipient (defaults to alecmazo1@gmail.com):
PORTFOLIO_EMAIL_TO=alecmazo1@gmail.com
# Sender Gmail credentials. Use a Gmail App Password (NOT your regular
# password). Create one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification on the Google account).
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
